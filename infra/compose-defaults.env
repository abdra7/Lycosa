# Committed zero-config defaults (ADR-022) so a fresh clone runs with:
#     docker compose -f infra/docker-compose.yml up --build -d
# No root .env is required; when one exists it overrides everything here.
#
# Safe-by-default reasoning:
#   - postgres/qdrant/prometheus ports are bound to 127.0.0.1 (compose file),
#     so the default DB password below is never reachable from the LAN
#   - JWT_SECRET and DEFAULT_ADMIN_PASSWORD are intentionally absent: the API
#     generates strong values on first run and persists them in the api_data
#     volume (data/runtime-secrets.json); the seed script prints the admin
#     password once in the api container logs
#   - ENVIRONMENT=production refuses to start on these defaults (issue #7)

ENVIRONMENT=development
LOG_LEVEL=info

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lycosa
POSTGRES_USER=lycosa
POSTGRES_PASSWORD=lycosa
DATABASE_URL=postgresql+asyncpg://lycosa:lycosa@postgres:5432/lycosa

QDRANT_URL=http://qdrant:6333

EMBEDDING_BACKEND=hashing
EMBEDDING_DIM=384
