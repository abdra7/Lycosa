# Copy this file to .env and fill in real values for local development.
# Never commit the real .env file.

# --- General ---
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=info                   # debug | info | warning | error

# --- API (backend) ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate limiting (per API key or client IP, in-process sliding window)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Default admin bootstrapped on first run (Sprint 1 seed script)
DEFAULT_ADMIN_EMAIL=admin@lycosa.local
DEFAULT_ADMIN_PASSWORD=change-me

# --- PostgreSQL (metadata store) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lycosa
POSTGRES_USER=lycosa
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://lycosa:change-me@postgres:5432/lycosa

# --- Qdrant (vector store) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# --- Node liveness (controller side) ---
# agents receive the interval from heartbeat responses; timeout ~3x interval
AGENT_HEARTBEAT_INTERVAL_SECONDS=5
HEARTBEAT_TIMEOUT_SECONDS=15
OFFLINE_SWEEP_INTERVAL_SECONDS=5

# --- Task dispatch ---
TASK_DISPATCH_TIMEOUT_SECONDS=120
TASK_MAX_ATTEMPTS=3

# --- Knowledge plane / embeddings ---
# hashing = deterministic, no downloads (keyword-level relevance)
# fastembed = semantic ONNX model, downloads ~90MB on first use
#             (requires: pip install "lycosa-backend[embeddings]")
EMBEDDING_BACKEND=hashing
EMBEDDING_DIM=384
# (the Local Agent itself is configured on its own machine via LYCOSA_* env
#  vars — see agent/README.md)

# --- Observability ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
# Grafana reads these natively (GF_* naming is Grafana's own convention)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me
